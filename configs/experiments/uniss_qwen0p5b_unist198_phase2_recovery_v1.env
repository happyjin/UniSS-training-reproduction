# Isolated Phase2 recovery. Both pilot and full runs load only model weights
# from the last stable Phase2 checkpoint, reset Adam/RNG, shuffle packed
# sequences with Megatron's cyclic sampler, and use a lower cosine LR.

USER_ROOT="${USER_ROOT:-/opt/dlami/nvme/jasonleeeli}"
ACTIVATE_SCRIPT="${ACTIVATE_SCRIPT:-${USER_ROOT}/env_recovery/uniss-train-20260721/activate_uniss.sh}"
ENV_ROOT="${ENV_ROOT:-${USER_ROOT}/conda_envs/uniss-train}"

TRAIN_DATA="${TRAIN_DATA:-${REPO_ROOT}/data/megatron/phase2_unist198_mix/packed_train.jsonl}"
VALID_DATA="${VALID_DATA:-${REPO_ROOT}/data/megatron/validation_unist_dev/phase2_valid_packed.jsonl}"

SOURCE_CHECKPOINT_ROOT="${SOURCE_CHECKPOINT_ROOT:-${REPO_ROOT}/checkpoints/uniss_qwen0p5b_phase2_unist198_full_v1}"
SOURCE_ITERATION="${SOURCE_ITERATION:-2300}"
EXPECTED_SOURCE_ITERATION="${EXPECTED_SOURCE_ITERATION:-2300}"
CANDIDATE_LOAD_ROOT="${CANDIDATE_LOAD_ROOT:-${REPO_ROOT}/checkpoints/candidates/uniss_qwen0p5b_phase2_unist198_iter2300}"

RECOVERY_NAME="${RECOVERY_NAME:-uniss_qwen0p5b_phase2_unist198_recovery_shuffle_lr5e5_v1}"
RECOVERY_CHECKPOINT_ROOT="${RECOVERY_CHECKPOINT_ROOT:-${REPO_ROOT}/checkpoints/${RECOVERY_NAME}}"
RECOVERY_RUN_ROOT="${RECOVERY_RUN_ROOT:-${REPO_ROOT}/runs/${RECOVERY_NAME}}"
RECOVERY_LOG_ROOT="${RECOVERY_LOG_ROOT:-${REPO_ROOT}/logs/${RECOVERY_NAME}}"

PILOT_SAVE_DIR="${PILOT_SAVE_DIR:-${RECOVERY_CHECKPOINT_ROOT}/pilot}"
PILOT_RUN_DIR="${PILOT_RUN_DIR:-${RECOVERY_RUN_ROOT}/pilot}"
PILOT_TENSORBOARD_DIR="${PILOT_TENSORBOARD_DIR:-${PILOT_RUN_DIR}/tensorboard}"
PILOT_LOG_PATH="${PILOT_LOG_PATH:-${RECOVERY_LOG_ROOT}_pilot.log}"
PILOT_TRAIN_ITERS="${PILOT_TRAIN_ITERS:-500}"
PILOT_LR_WARMUP_ITERS="${PILOT_LR_WARMUP_ITERS:-100}"
PILOT_EVAL_INTERVAL="${PILOT_EVAL_INTERVAL:-50}"
PILOT_MASTER_PORT="${PILOT_MASTER_PORT:-29622}"

FULL_SAVE_DIR="${FULL_SAVE_DIR:-${RECOVERY_CHECKPOINT_ROOT}/full}"
FULL_RUN_DIR="${FULL_RUN_DIR:-${RECOVERY_RUN_ROOT}/full}"
FULL_TENSORBOARD_DIR="${FULL_TENSORBOARD_DIR:-${FULL_RUN_DIR}/tensorboard}"
FULL_LOG_PATH="${FULL_LOG_PATH:-${RECOVERY_LOG_ROOT}_full.log}"
FULL_TRAIN_ITERS="${FULL_TRAIN_ITERS:-15381}"
FULL_LR_WARMUP_ITERS="${FULL_LR_WARMUP_ITERS:-500}"
FULL_EVAL_INTERVAL="${FULL_EVAL_INTERVAL:-100}"
FULL_MASTER_PORT="${FULL_MASTER_PORT:-29623}"

CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"
NPROC_PER_NODE="${NPROC_PER_NODE:-8}"
TP="${TP:-1}"
PP="${PP:-1}"
MICRO_BATCH_SIZE="${MICRO_BATCH_SIZE:-2}"
GLOBAL_BATCH_SIZE="${GLOBAL_BATCH_SIZE:-128}"

LR="${LR:-5e-5}"
MIN_LR="${MIN_LR:-5e-6}"
LR_DECAY_STYLE="${LR_DECAY_STYLE:-cosine}"
DATALOADER_TYPE="${DATALOADER_TYPE:-cyclic}"
NO_DATA_SHARDING="${NO_DATA_SHARDING:-0}"
FULL_VALIDATION="${FULL_VALIDATION:-0}"
EVAL_MICRO_BATCH_SIZE="${EVAL_MICRO_BATCH_SIZE:-}"
EVAL_GLOBAL_BATCH_SIZE="${EVAL_GLOBAL_BATCH_SIZE:-}"
CLIP_GRAD="${CLIP_GRAD:-1.0}"
SEED="${SEED:-20260723}"

SAVE_INTERVAL="${SAVE_INTERVAL:-100}"
EVAL_ITERS="${EVAL_ITERS:-10}"
LOG_INTERVAL="${LOG_INTERVAL:-10}"
TENSORBOARD_LOG_INTERVAL="${TENSORBOARD_LOG_INTERVAL:-10}"
TENSORBOARD_MEMORY_INTERVAL="${TENSORBOARD_MEMORY_INTERVAL:-10}"
TENSORBOARD_PORT="${TENSORBOARD_PORT:-6009}"

PILOT_MAX_VALID_LOSS="${PILOT_MAX_VALID_LOSS:-5.3}"
PILOT_MAX_LAST_VALID_LOSS="${PILOT_MAX_LAST_VALID_LOSS:-5.0}"
PILOT_GRAD_SPIKE_THRESHOLD="${PILOT_GRAD_SPIKE_THRESHOLD:-20.0}"
PILOT_MAX_CONSECUTIVE_GRAD_SPIKES="${PILOT_MAX_CONSECUTIVE_GRAD_SPIKES:-4}"
PILOT_ABSOLUTE_MAX_GRAD_NORM="${PILOT_ABSOLUTE_MAX_GRAD_NORM:-}"
