# Isolated 15-shard bootstrap configuration for Simul-UniSS.

USER_ROOT="${USER_ROOT:-/opt/dlami/nvme/jasonleeeli}"
ACTIVATE_SCRIPT="${ACTIVATE_SCRIPT:-${USER_ROOT}/env_recovery/uniss-train-20260721/activate_uniss.sh}"

SIMUL_EXPERIMENT="${SIMUL_EXPERIMENT:-simul_uniss_v1_bootstrap_15shard}"
UNIST_ROOT="${UNIST_ROOT:-${REPO_ROOT}/data/raw/UniST}"
TOKENIZER_DIR="${TOKENIZER_DIR:-${REPO_ROOT}/pretrained_models/UniSS}"
SHARD_START="${SHARD_START:-0}"
SHARD_COUNT="${SHARD_COUNT:-15}"

CHUNK_MS="${CHUNK_MS:-640}"
WAIT_K_CHUNKS="${WAIT_K_CHUNKS:-2}"
MAX_PHRASE_TOKENS="${MAX_PHRASE_TOKENS:-16}"
SEQ_LENGTH="${SEQ_LENGTH:-4096}"

PROCESSED_DIR="${PROCESSED_DIR:-${REPO_ROOT}/data/processed/simul_uniss_v1/bootstrap_15shard}"
PACKED_DIR="${PACKED_DIR:-${REPO_ROOT}/data/megatron/simul_uniss_v1/bootstrap_15shard}"
RUN_DIR="${RUN_DIR:-${REPO_ROOT}/runs/simul_uniss_v1/bootstrap_15shard}"
TENSORBOARD_DIR="${TENSORBOARD_DIR:-${RUN_DIR}/tensorboard}"
LOG_DIR="${LOG_DIR:-${REPO_ROOT}/logs/simul_uniss_v1}"

SCHEDULES_JSONL="${SCHEDULES_JSONL:-${PROCESSED_DIR}/schedules.jsonl}"
SAMPLES_JSONL="${SAMPLES_JSONL:-${PROCESSED_DIR}/samples.jsonl}"
PACKED_TRAIN="${PACKED_TRAIN:-${PACKED_DIR}/packed_train.jsonl}"
STAGE0_METRICS="${STAGE0_METRICS:-${RUN_DIR}/stage0_metrics.json}"

# Read-only initialization root. Megatron reads latest_checkpointed_iteration.txt.
QWEN_CHECKPOINT_ROOT="${QWEN_CHECKPOINT_ROOT:-${REPO_ROOT}/checkpoints/uniss_qwen0p5b_phase1_unist198_recovery_b1_v2}"
SIMUL_CHECKPOINT_ROOT="${SIMUL_CHECKPOINT_ROOT:-${REPO_ROOT}/checkpoints/simul_uniss_v1}"

TENSORBOARD_PORT="${TENSORBOARD_PORT:-6008}"
TENSORBOARD_SESSION="${TENSORBOARD_SESSION:-simul_uniss_v1_tensorboard}"

POLICY_TOKENIZER_DIR="${POLICY_TOKENIZER_DIR:-${PROCESSED_DIR}/policy_tokenizer}"
POLICY_TOKENIZER_MODEL="${POLICY_TOKENIZER_MODEL:-${POLICY_TOKENIZER_DIR}/policy_8k.model}"
POLICY_VOCAB_SIZE="${POLICY_VOCAB_SIZE:-8192}"

STAGE1_OUTPUT_DIR="${STAGE1_OUTPUT_DIR:-${SIMUL_CHECKPOINT_ROOT}/stage1_bootstrap_student_15shard}"
STAGE1_DEVICE="${STAGE1_DEVICE:-cuda}"
STAGE1_BATCH_SIZE="${STAGE1_BATCH_SIZE:-2}"
STAGE1_MAX_STEPS="${STAGE1_MAX_STEPS:-1000}"
STAGE1_LEARNING_RATE="${STAGE1_LEARNING_RATE:-1e-4}"
STAGE1_HIDDEN_SIZE="${STAGE1_HIDDEN_SIZE:-256}"
STAGE1_NUM_LAYERS="${STAGE1_NUM_LAYERS:-4}"
STAGE1_NUM_HEADS="${STAGE1_NUM_HEADS:-8}"
STAGE1_MAX_SOURCE_TOKENS="${STAGE1_MAX_SOURCE_TOKENS:-1024}"
STAGE1_VALIDATION_RECORDS="${STAGE1_VALIDATION_RECORDS:-128}"
STAGE1_EVAL_INTERVAL="${STAGE1_EVAL_INTERVAL:-100}"
STAGE1_SAVE_INTERVAL="${STAGE1_SAVE_INTERVAL:-100}"
