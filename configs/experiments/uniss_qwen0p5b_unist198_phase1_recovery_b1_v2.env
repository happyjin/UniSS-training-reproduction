# Isolated Phase1 recovery experiment B1 v2. It loads only the model weights
# from iteration 3300, resets Adam/RNG, shuffles the packed training sequences,
# and uses a lower cosine-decayed learning rate for a 500-iteration stability
# run. V2 uses the established sampled-validation path because this Megatron-LM
# revision has a scalar/list bug in single-dataset --full-validation.

USER_ROOT="${USER_ROOT:-/opt/dlami/nvme/jasonleeeli}"
ACTIVATE_SCRIPT="${ACTIVATE_SCRIPT:-${USER_ROOT}/env_recovery/uniss-train-20260721/activate_uniss.sh}"

EXPERIMENT_NAME="${EXPERIMENT_NAME:-uniss_qwen0p5b_phase1_unist198_recovery_b1_v2}"

TRAIN_DATA="${TRAIN_DATA:-${REPO_ROOT}/data/megatron/phase1_unist198/packed_train.jsonl}"
VALID_DATA="${VALID_DATA:-${REPO_ROOT}/data/megatron/validation_unist_dev/phase1_valid_packed.jsonl}"

SOURCE_CHECKPOINT_ROOT="${SOURCE_CHECKPOINT_ROOT:-${REPO_ROOT}/checkpoints/uniss_qwen0p5b_phase1_unist198_full_v1}"
SOURCE_ITERATION="${SOURCE_ITERATION:-3300}"
CANDIDATE_LOAD_ROOT="${CANDIDATE_LOAD_ROOT:-${REPO_ROOT}/checkpoints/candidates/uniss_qwen0p5b_phase1_unist198_iter3300}"

SAVE_DIR="${SAVE_DIR:-${REPO_ROOT}/checkpoints/${EXPERIMENT_NAME}}"
RUN_DIR="${RUN_DIR:-${REPO_ROOT}/runs/${EXPERIMENT_NAME}}"
TENSORBOARD_DIR="${TENSORBOARD_DIR:-${RUN_DIR}/tensorboard}"
LOG_PATH="${LOG_PATH:-${REPO_ROOT}/logs/${EXPERIMENT_NAME}.log}"

CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"
NPROC_PER_NODE="${NPROC_PER_NODE:-8}"
TP="${TP:-1}"
PP="${PP:-1}"
MICRO_BATCH_SIZE="${MICRO_BATCH_SIZE:-2}"
GLOBAL_BATCH_SIZE="${GLOBAL_BATCH_SIZE:-128}"

TRAIN_ITERS="${TRAIN_ITERS:-500}"
LR="${LR:-1e-4}"
MIN_LR="${MIN_LR:-1e-5}"
LR_WARMUP_ITERS="${LR_WARMUP_ITERS:-200}"
LR_DECAY_STYLE="${LR_DECAY_STYLE:-cosine}"
LR_DECAY_ITERS="${LR_DECAY_ITERS:-500}"
SEED="${SEED:-20260721}"

SAVE_INTERVAL="${SAVE_INTERVAL:-100}"
EVAL_INTERVAL="${EVAL_INTERVAL:-100}"
EVAL_ITERS="${EVAL_ITERS:-10}"
LOG_INTERVAL="${LOG_INTERVAL:-10}"
TENSORBOARD_LOG_INTERVAL="${TENSORBOARD_LOG_INTERVAL:-10}"
TENSORBOARD_MEMORY_INTERVAL="${TENSORBOARD_MEMORY_INTERVAL:-10}"
MASTER_PORT="${MASTER_PORT:-29614}"
TENSORBOARD_PORT="${TENSORBOARD_PORT:-6007}"
