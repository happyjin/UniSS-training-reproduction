# Isolated full UniST-198 experiment. Values may be overridden in the caller's
# environment before sourcing this file.

USER_ROOT="${USER_ROOT:-/opt/dlami/nvme/jasonleeeli}"
ACTIVATE_SCRIPT="${ACTIVATE_SCRIPT:-${USER_ROOT}/env_recovery/uniss-train-20260721/activate_uniss.sh}"
ENV_ROOT="${ENV_ROOT:-${USER_ROOT}/conda_envs/uniss-train}"

EXPERIMENT_NAME="${EXPERIMENT_NAME:-uniss_qwen0p5b_unist198_full_v1}"
TOKENIZER_DIR="${TOKENIZER_DIR:-${REPO_ROOT}/pretrained_models/UniSS}"

PHASE1_SOURCE_DIR="${PHASE1_SOURCE_DIR:-${REPO_ROOT}/data/processed/phase1_unist198_sharded}"
PHASE2_SOURCE="${PHASE2_SOURCE:-${REPO_ROOT}/data/processed/phase2_unist198_mix/phase2_mix_2to1.jsonl}"
PHASE3_SOURCE_DIR="${PHASE3_SOURCE_DIR:-${REPO_ROOT}/data/processed/phase3_unist198_sharded}"
UNIST_DEV_PARQUET="${UNIST_DEV_PARQUET:-${REPO_ROOT}/data/raw/UniST/dev-00000.parquet}"
PHASE3_DEV_SOURCE="${PHASE3_DEV_SOURCE:-${REPO_ROOT}/data/processed/validation_unist_dev/phase3_dev.jsonl}"

PHASE1_TRAIN="${PHASE1_TRAIN:-${REPO_ROOT}/data/megatron/phase1_unist198/packed_train.jsonl}"
PHASE1_VALID="${PHASE1_VALID:-${REPO_ROOT}/data/megatron/validation_unist_dev/phase1_valid_packed.jsonl}"
PHASE2_TRAIN="${PHASE2_TRAIN:-${REPO_ROOT}/data/megatron/phase2_unist198_mix/packed_train.jsonl}"
PHASE2_VALID="${PHASE2_VALID:-${REPO_ROOT}/data/megatron/validation_unist_dev/phase2_valid_packed.jsonl}"
PHASE3_TRAIN="${PHASE3_TRAIN:-${REPO_ROOT}/data/megatron/phase3_unist198/packed_train.jsonl}"
PHASE3_VALID="${PHASE3_VALID:-${REPO_ROOT}/data/megatron/validation_unist_dev/phase3_valid_packed.jsonl}"

PACK_RUN_DIR="${PACK_RUN_DIR:-${REPO_ROOT}/runs/unist198_preprocess}"
PACKING_COMPLETE_MARKER="${PACKING_COMPLETE_MARKER:-${PACK_RUN_DIR}/PACKING_COMPLETE_V1}"

BASE_CHECKPOINT="${BASE_CHECKPOINT:-${REPO_ROOT}/checkpoints/qwen2_0p5b_uniss_vocab}"
PHASE1_SAVE="${PHASE1_SAVE:-${REPO_ROOT}/checkpoints/uniss_qwen0p5b_phase1_unist198_full_v1}"
PHASE2_SAVE="${PHASE2_SAVE:-${REPO_ROOT}/checkpoints/uniss_qwen0p5b_phase2_unist198_full_v1}"
PHASE3_SAVE="${PHASE3_SAVE:-${REPO_ROOT}/checkpoints/uniss_qwen0p5b_phase3_unist198_full_v1}"

RUN_DIR="${RUN_DIR:-${REPO_ROOT}/runs/${EXPERIMENT_NAME}}"
TENSORBOARD_ROOT="${TENSORBOARD_ROOT:-${RUN_DIR}/tensorboard}"
PHASE1_LOG="${PHASE1_LOG:-${REPO_ROOT}/logs/uniss_qwen0p5b_phase1_unist198_full_v1.log}"
PHASE2_LOG="${PHASE2_LOG:-${REPO_ROOT}/logs/uniss_qwen0p5b_phase2_unist198_full_v1.log}"
PHASE3_LOG="${PHASE3_LOG:-${REPO_ROOT}/logs/uniss_qwen0p5b_phase3_unist198_full_v1.log}"
PIPELINE_LOG="${PIPELINE_LOG:-${REPO_ROOT}/logs/uniss_qwen0p5b_unist198_full_v1_pipeline.log}"

CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"
NPROC_PER_NODE="${NPROC_PER_NODE:-8}"
TP="${TP:-1}"
PP="${PP:-1}"
MICRO_BATCH_SIZE="${MICRO_BATCH_SIZE:-2}"
GLOBAL_BATCH_SIZE="${GLOBAL_BATCH_SIZE:-128}"
SEQ_LENGTH="${SEQ_LENGTH:-18000}"
PACK_WORKERS="${PACK_WORKERS:-8}"

SAVE_INTERVAL="${SAVE_INTERVAL:-100}"
EVAL_INTERVAL="${EVAL_INTERVAL:-100}"
EVAL_ITERS="${EVAL_ITERS:-10}"
LOG_INTERVAL="${LOG_INTERVAL:-10}"
TENSORBOARD_LOG_INTERVAL="${TENSORBOARD_LOG_INTERVAL:-10}"
TENSORBOARD_MEMORY_INTERVAL="${TENSORBOARD_MEMORY_INTERVAL:-10}"

PHASE1_MASTER_PORT="${PHASE1_MASTER_PORT:-29611}"
PHASE2_MASTER_PORT="${PHASE2_MASTER_PORT:-29612}"
PHASE3_MASTER_PORT="${PHASE3_MASTER_PORT:-29613}"
