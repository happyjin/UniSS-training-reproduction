# Phase2 v4: clean Phase1 -> Phase2 transition on the existing full UniST-198
# packed mix. The first 3000 updates are a fixed inspection boundary, not an
# online early-stop policy. A passing run resumes the same optimizer, RNG,
# scheduler, and data cursor through one complete packed-data epoch.

USER_ROOT="${USER_ROOT:-/opt/dlami/nvme/jasonleeeli}"
ACTIVATE_SCRIPT="${ACTIVATE_SCRIPT:-${USER_ROOT}/env_recovery/uniss-train-20260721/activate_uniss.sh}"
ENV_ROOT="${ENV_ROOT:-${USER_ROOT}/conda_envs/uniss-train}"

TRAIN_DATA="${TRAIN_DATA:-${REPO_ROOT}/data/megatron/phase2_unist198_mix/packed_train.jsonl}"
VALID_DATA="${VALID_DATA:-${REPO_ROOT}/data/megatron/validation_unist_dev/phase2_valid_packed.jsonl}"
EXPECTED_TRAIN_PACKED_COUNT="${EXPECTED_TRAIN_PACKED_COUNT:-1968716}"

SOURCE_CHECKPOINT_ROOT="${SOURCE_CHECKPOINT_ROOT:-${REPO_ROOT}/checkpoints/uniss_qwen0p5b_phase1_unist198_recovery_b1_v2}"
SOURCE_ITERATION="${SOURCE_ITERATION:-15465}"
EXPECTED_SOURCE_ITERATION="${EXPECTED_SOURCE_ITERATION:-15465}"
CANDIDATE_LOAD_ROOT="${CANDIDATE_LOAD_ROOT:-${REPO_ROOT}/checkpoints/candidates/uniss_qwen0p5b_phase1_unist198_recovery_b1_v2_iter15465}"

EXPERIMENT_NAME="${EXPERIMENT_NAME:-uniss_qwen0p5b_phase2_unist198_from_phase1_fast_decay_v4}"
SAVE_DIR="${SAVE_DIR:-${REPO_ROOT}/checkpoints/${EXPERIMENT_NAME}}"
RUN_DIR="${RUN_DIR:-${REPO_ROOT}/runs/${EXPERIMENT_NAME}}"
TENSORBOARD_DIR="${TENSORBOARD_DIR:-${RUN_DIR}/tensorboard}"
TENSORBOARD_ROOT="${TENSORBOARD_ROOT:-${TENSORBOARD_DIR}}"
LOG_PATH="${LOG_PATH:-${REPO_ROOT}/logs/${EXPERIMENT_NAME}.log}"

TRAIN_ITERS="${TRAIN_ITERS:-15381}"
PILOT_EXIT_ITERATION="${PILOT_EXIT_ITERATION:-3000}"
LR="${LR:-1e-5}"
MIN_LR="${MIN_LR:-1e-6}"
LR_DECAY_STYLE="${LR_DECAY_STYLE:-cosine}"
LR_DECAY_ITERS="${LR_DECAY_ITERS:-3000}"
LR_WARMUP_ITERS="${LR_WARMUP_ITERS:-400}"

CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"
NPROC_PER_NODE="${NPROC_PER_NODE:-8}"
TP="${TP:-1}"
PP="${PP:-1}"
MICRO_BATCH_SIZE="${MICRO_BATCH_SIZE:-2}"
GLOBAL_BATCH_SIZE="${GLOBAL_BATCH_SIZE:-128}"
DATALOADER_TYPE="${DATALOADER_TYPE:-cyclic}"
NO_DATA_SHARDING="${NO_DATA_SHARDING:-1}"
FULL_VALIDATION="${FULL_VALIDATION:-1}"
EVAL_MICRO_BATCH_SIZE="${EVAL_MICRO_BATCH_SIZE:-1}"
EVAL_GLOBAL_BATCH_SIZE="${EVAL_GLOBAL_BATCH_SIZE:-8}"
CLIP_GRAD="${CLIP_GRAD:-0.5}"
SEED="${SEED:-20260727}"

SAVE_INTERVAL="${SAVE_INTERVAL:-100}"
EVAL_INTERVAL="${EVAL_INTERVAL:-100}"
EVAL_ITERS="${EVAL_ITERS:-10}"
LOG_INTERVAL="${LOG_INTERVAL:-10}"
TENSORBOARD_LOG_INTERVAL="${TENSORBOARD_LOG_INTERVAL:-10}"
TENSORBOARD_MEMORY_INTERVAL="${TENSORBOARD_MEMORY_INTERVAL:-10}"
MASTER_PORT="${MASTER_PORT:-29630}"
TENSORBOARD_PORT="${TENSORBOARD_PORT:-6014}"
TRAIN_SESSION="${TRAIN_SESSION:-uniss_phase2_from_phase1_v4}"
TENSORBOARD_SESSION="${TENSORBOARD_SESSION:-uniss_phase2_from_phase1_v4_tensorboard}"

# Fixed-boundary health gates. No online early-stop hook is enabled.
PILOT_MAX_VALID_LOSS="${PILOT_MAX_VALID_LOSS:-6.0}"
PILOT_MAX_LAST_VALID_LOSS="${PILOT_MAX_LAST_VALID_LOSS:-5.0}"
PILOT_MAX_LAST_MINUS_BEST="${PILOT_MAX_LAST_MINUS_BEST:-0.05}"
PILOT_GRAD_SPIKE_THRESHOLD="${PILOT_GRAD_SPIKE_THRESHOLD:-10.0}"
PILOT_MAX_CONSECUTIVE_GRAD_SPIKES="${PILOT_MAX_CONSECUTIVE_GRAD_SPIKES:-1}"
PILOT_ABSOLUTE_MAX_GRAD_NORM="${PILOT_ABSOLUTE_MAX_GRAD_NORM:-20.0}"

FINAL_MAX_VALID_LOSS="${FINAL_MAX_VALID_LOSS:-6.0}"
FINAL_MAX_LAST_VALID_LOSS="${FINAL_MAX_LAST_VALID_LOSS:-5.0}"
FINAL_MAX_LAST_MINUS_BEST="${FINAL_MAX_LAST_MINUS_BEST:-0.02}"
FINAL_GRAD_SPIKE_THRESHOLD="${FINAL_GRAD_SPIKE_THRESHOLD:-10.0}"
FINAL_MAX_CONSECUTIVE_GRAD_SPIKES="${FINAL_MAX_CONSECUTIVE_GRAD_SPIKES:-1}"
FINAL_ABSOLUTE_MAX_GRAD_NORM="${FINAL_ABSOLUTE_MAX_GRAD_NORM:-20.0}"
