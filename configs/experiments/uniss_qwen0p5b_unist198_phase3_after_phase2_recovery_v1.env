# Isolated full-data Phase3 launched only after the shuffled Phase2 recovery
# reaches its final checkpoint and passes the same TensorBoard/log health gate.

USER_ROOT="${USER_ROOT:-/opt/dlami/nvme/jasonleeeli}"
ACTIVATE_SCRIPT="${ACTIVATE_SCRIPT:-${USER_ROOT}/env_recovery/uniss-train-20260721/activate_uniss.sh}"
ENV_ROOT="${ENV_ROOT:-${USER_ROOT}/conda_envs/uniss-train}"

PHASE2_NAME="${PHASE2_NAME:-uniss_qwen0p5b_phase2_unist198_recovery_shuffle_lr5e5_v1}"
PHASE2_SAVE_DIR="${PHASE2_SAVE_DIR:-${REPO_ROOT}/checkpoints/${PHASE2_NAME}/full}"
PHASE2_RUN_DIR="${PHASE2_RUN_DIR:-${REPO_ROOT}/runs/${PHASE2_NAME}/full}"
PHASE2_TENSORBOARD_DIR="${PHASE2_TENSORBOARD_DIR:-${PHASE2_RUN_DIR}/tensorboard}"
PHASE2_LOG_PATH="${PHASE2_LOG_PATH:-${REPO_ROOT}/logs/${PHASE2_NAME}_full.log}"
PHASE2_TRAIN_ITERS="${PHASE2_TRAIN_ITERS:-15381}"

PHASE2_MAX_VALID_LOSS="${PHASE2_MAX_VALID_LOSS:-5.3}"
PHASE2_MAX_LAST_VALID_LOSS="${PHASE2_MAX_LAST_VALID_LOSS:-5.0}"
PHASE2_GRAD_SPIKE_THRESHOLD="${PHASE2_GRAD_SPIKE_THRESHOLD:-20.0}"
PHASE2_MAX_CONSECUTIVE_GRAD_SPIKES="${PHASE2_MAX_CONSECUTIVE_GRAD_SPIKES:-4}"

PHASE3_NAME="${PHASE3_NAME:-uniss_qwen0p5b_phase3_unist198_from_phase2_recovery_v1}"
PHASE3_TRAIN="${PHASE3_TRAIN:-${REPO_ROOT}/data/megatron/phase3_unist198/packed_train.jsonl}"
PHASE3_VALID="${PHASE3_VALID:-${REPO_ROOT}/data/megatron/validation_unist_dev/phase3_valid_packed.jsonl}"
PHASE3_SAVE_DIR="${PHASE3_SAVE_DIR:-${REPO_ROOT}/checkpoints/${PHASE3_NAME}}"
# Keep Phase3 TensorBoard below the existing Phase2 recovery log root so the
# already-running TensorBoard on port 6009 discovers it automatically.
PHASE3_RUN_DIR="${PHASE3_RUN_DIR:-${REPO_ROOT}/runs/${PHASE2_NAME}/phase3}"
PHASE3_TENSORBOARD_DIR="${PHASE3_TENSORBOARD_DIR:-${PHASE3_RUN_DIR}/tensorboard}"
PHASE3_LOG_PATH="${PHASE3_LOG_PATH:-${REPO_ROOT}/logs/${PHASE3_NAME}.log}"
PHASE3_TRAIN_ITERS="${PHASE3_TRAIN_ITERS:-9075}"
PHASE3_LR_WARMUP_ITERS="${PHASE3_LR_WARMUP_ITERS:-0}"
PHASE3_MASTER_PORT="${PHASE3_MASTER_PORT:-29624}"

CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0,1,2,3,4,5,6,7}"
NPROC_PER_NODE="${NPROC_PER_NODE:-8}"
TP="${TP:-1}"
PP="${PP:-1}"
MICRO_BATCH_SIZE="${MICRO_BATCH_SIZE:-2}"
GLOBAL_BATCH_SIZE="${GLOBAL_BATCH_SIZE:-128}"
DATALOADER_TYPE="${DATALOADER_TYPE:-cyclic}"
SEED="${SEED:-20260724}"
CLIP_GRAD="${CLIP_GRAD:-1.0}"

SAVE_INTERVAL="${SAVE_INTERVAL:-100}"
EVAL_INTERVAL="${EVAL_INTERVAL:-100}"
EVAL_ITERS="${EVAL_ITERS:-10}"
LOG_INTERVAL="${LOG_INTERVAL:-10}"
TENSORBOARD_LOG_INTERVAL="${TENSORBOARD_LOG_INTERVAL:-10}"
TENSORBOARD_MEMORY_INTERVAL="${TENSORBOARD_MEMORY_INTERVAL:-10}"
POLL_SECONDS="${POLL_SECONDS:-60}"
